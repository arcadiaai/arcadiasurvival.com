---
import Marketing from '../layouts/Marketing.astro';
import PlaceholderImage from '../components/PlaceholderImage.astro';

const sections = [
  { id: 'llm', title: 'Local AI', body: "A 35B Mixture-of-Experts AI model running natively on the appliance with 80–85 tokens/sec throughput. Eight domain agents (Survival, Medical, Agriculture, Technical, Civics, Comms, Navigation, Security) route your question to the right knowledge base. No cloud, no API keys, no metering." },
  { id: 'kiwix', title: 'Over 160 GB of archives', body: 'Encyclopedias, reference books, military and medical manuals, agricultural extension guides, plant identification — all searchable and offline.' },
  { id: 'add-docs', title: 'Bring your own documents', body: 'Upload PDFs, text files, or paste a URL and ARCADIA fetches and indexes it. Your documents are auto-categorized, approved by you, and then referenced by the AI alongside the built-in library. A nightly reindex keeps everything current automatically.' },
  { id: 'maps', title: 'Planet-scale offline maps', body: '120 GB of offline map data with built-in address search. Find any address in any country and drop pins to mark places — all offline.' },
  { id: 'kolibri', title: 'Educational courses', optional: true, body: 'Install the educational pack to ship a full offline course library with progress tracking per device. Kids keep studying when the internet is out.' },
  { id: 'voice', title: 'Hands-free voice', body: 'Browser-based: tap the microphone, speak, hear ARCADIA respond out loud through the optional USB speaker puck. Eight TTS voice options.' },
  { id: 'translate', title: 'Translation', optional: true, body: 'On-device translation models for major world languages. Translate documents, search results, or speech — running locally.' },
  { id: 'aviation', title: 'Aviation and maritime', body: 'FAA approach plates, sectional charts, NOAA marine charts, and aviation reference manuals — searchable, browsable, offline.' },
  { id: 'plants', title: 'Plant identification', optional: true, body: 'Edible plant database, herb references, and identification guides with image-search support.' },
];
---
<Marketing title="Features" description="Eight knowledge domains served from one appliance.">
  <div class="page">
    <header class="header">
      <p class="eyebrow">FEATURES</p>
      <h1>One appliance. Eight knowledge domains. Zero internet.</h1>
    </header>

    {sections.map((s, i) => (
      <section id={s.id} class:list={['section', { reversed: i % 2 === 1 }]}>
        <div class="text">
          <h2>{s.title}</h2>
          {s.optional && <p class="optional">(Optional User Install)</p>}
          <p>{s.body}</p>
        </div>
        <div class="visual">
          <PlaceholderImage slot={`feature-${s.id}`} width={1200} height={800} />
        </div>
      </section>
    ))}
  </div>
</Marketing>

<style>
  .page { max-width: var(--container); margin: 0 auto; padding: var(--space-7) var(--space-4); }
  .header { margin-bottom: var(--space-7); }
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  h1 { font-size: var(--step-4); max-width: 38rem; }
  .section {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--rule);
  }
  .section.reversed { grid-template-columns: 1.2fr 1fr; }
  .section.reversed .text { order: 2; }
  .text h2 { font-size: var(--step-3); margin-bottom: var(--space-3); }
  .text p { font-family: var(--serif); font-size: var(--step-1); line-height: 1.6; color: var(--ink-muted); }
  .text .optional {
    margin-bottom: var(--space-3);
  }
  @media (max-width: 800px) {
    .section, .section.reversed { grid-template-columns: 1fr; }
    .section.reversed .text { order: 0; }
  }
</style>
