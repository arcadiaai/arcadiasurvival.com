---
import Marketing from '../layouts/Marketing.astro';
import PlaceholderImage from '../components/PlaceholderImage.astro';

const sections = [
  { id: 'llm', title: 'Local AI', body: "GPT-OSS-120B running natively on the appliance with 47–54 tokens/sec throughput. Eight domain agents (Survival, Medical, Agriculture, Technical, Civics, Comms, Navigation, Security) route your question to the right knowledge base. No cloud, no API keys, no metering." },
  { id: 'kiwix', title: 'Wikipedia and reference library', body: 'Around 160 GB of ZIM-format archives: Wikipedia, Wikivoyage, Wikibooks, Wiktionary, Project Gutenberg, military and medical manuals, agricultural extension guides, plant identification.' },
  { id: 'maps', title: 'Planet-scale offline maps', body: '120 GB of OpenStreetMap PMTiles plus a Photon geocoder. Search any address in any country, drop pins, plan routes — all offline.' },
  { id: 'kolibri', title: 'Khan Academy (optional)', body: 'Install the Khan Academy pack to ship a full offline course library with progress tracking per device. Kids keep studying when the internet is out.' },
  { id: 'voice', title: 'Hands-free voice', body: 'Browser-based: tap the microphone, speak, hear ARCADIA respond out loud through the optional USB speaker puck. Eight TTS voice options.' },
  { id: 'translate', title: 'Translation (optional)', body: '24 language pairs powered by Argos OpenNMT models, running locally. Translate documents, search, or speech.' },
  { id: 'aviation', title: 'Aviation and maritime', body: 'FAA approach plates, sectional charts, NOAA marine charts, and aviation reference manuals — searchable, browsable, offline.' },
  { id: 'plants', title: 'Plant identification and homestead', body: 'Plants For A Future database, herb references, edible plant guides, with image-search support.' },
];
---
<Marketing title="Features" description="Eight knowledge domains served from one appliance.">
  <div class="page">
    <header class="header">
      <p class="eyebrow">FEATURES</p>
      <h1>One appliance. Eight knowledge domains. Zero internet.</h1>
    </header>

    {sections.map((s, i) => (
      <section id={s.id} class:list={['section', { reversed: i % 2 === 1 }]}>
        <div class="text">
          <h2>{s.title}</h2>
          <p>{s.body}</p>
        </div>
        <div class="visual">
          <PlaceholderImage slot={`feature-${s.id}`} width={1200} height={800} />
        </div>
      </section>
    ))}
  </div>
</Marketing>

<style>
  .page { max-width: var(--container); margin: 0 auto; padding: var(--space-7) var(--space-4); }
  .header { margin-bottom: var(--space-7); }
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  h1 { font-size: var(--step-4); max-width: 38rem; }
  .section {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-6) 0;
    border-top: 1px solid var(--rule);
  }
  .section.reversed { grid-template-columns: 1.2fr 1fr; }
  .section.reversed .text { order: 2; }
  .text h2 { font-size: var(--step-3); margin-bottom: var(--space-3); }
  .text p { font-family: var(--serif); font-size: var(--step-1); line-height: 1.6; color: var(--ink-muted); }
  @media (max-width: 800px) {
    .section, .section.reversed { grid-template-columns: 1fr; }
    .section.reversed .text { order: 0; }
  }
</style>
