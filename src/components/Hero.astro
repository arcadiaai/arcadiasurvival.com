---
import PlaceholderImage from './PlaceholderImage.astro';
import WaitlistForm from './WaitlistForm.astro';
---
<section class="hero">
  <div class="left">
    <p class="eyebrow">OFFLINE · LOCAL · NO ACCOUNTS</p>
    <h1>The library that works when nothing else does.</h1>
    <p class="lede">
      ARCADIA is a self-contained survival knowledge appliance.
      Encyclopedias, offline maps, medical references, language tools,
      and a private AI — all running offline from a single quiet box
      on your kitchen counter.
    </p>
    <WaitlistForm source="home" />
  </div>
  <div class="right">
    <PlaceholderImage slot="hero-unit" width={1200} height={1500} caption="Hero photo of the appliance." />
  </div>
</section>

<style>
  .hero {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-7) var(--space-4) var(--space-6);
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: var(--space-3);
  }
  h1 { font-size: var(--step-5); margin-bottom: var(--space-4); }
  .lede {
    font-family: var(--serif);
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--ink-muted);
    margin-bottom: var(--space-5);
    max-width: 36rem;
  }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; gap: var(--space-5); }
    h1 { font-size: var(--step-4); }
  }
</style>
