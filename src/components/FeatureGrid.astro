---
import FeatureCard from './FeatureCard.astro';

const features = [
  { icon: '🤖', title: 'Local AI', body: 'A 120B-parameter LLM running natively on the appliance. No cloud, no API keys, no metering.' },
  { icon: '📚', title: 'Over 160 GB of archives', body: 'Encyclopedias, reference books, military and medical manuals, and other public-domain resources.' },
  { icon: '🗺️', title: 'Planet-scale offline maps', body: '120 GB of offline map data with built-in address search. Find any address worldwide — no internet required.' },
  { icon: '🎤', title: 'Hands-free voice', body: 'Speak questions, hear answers — local text-to-speech plus a USB speaker puck. Works in a power outage.' },
];
---
<section class="grid">
  {features.map(f => (
    <FeatureCard title={f.title} icon={f.icon}>{f.body}</FeatureCard>
  ))}
</section>

<style>
  .grid {
    max-width: var(--container);
    margin: 0 auto;
    padding: var(--space-6) var(--space-4);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px) { .grid { grid-template-columns: 1fr; } }
</style>
