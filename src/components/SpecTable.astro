---
interface Props { title: string; }
const { title } = Astro.props;
---
<section class="table">
  <h3>{title}</h3>
  <div class="rows"><slot /></div>
</section>

<style>
  .table {
    background: var(--tech-bg);
    color: var(--tech-fg);
    padding: var(--space-5);
    border-radius: var(--radius);
  }
  .table :global(.row) { border-color: rgba(245,241,232,0.2); }
  .table :global(.label), .table :global(.value) { color: var(--tech-fg); }
  .table h3 {
    font-family: var(--mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--warn);
    margin-bottom: var(--space-3);
  }
</style>
