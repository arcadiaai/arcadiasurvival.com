---
const year = new Date().getFullYear();
---
<footer>
  <div class="inner">
    <div class="col">
      <p class="brand">ARCADIA</p>
      <p class="tagline">Offline survival knowledge appliance.</p>
    </div>
    <div class="col">
      <p class="heading">Product</p>
      <a href="/features">Features</a>
      <a href="/specs">Specs</a>
      <a href="/waitlist">Waitlist</a>
    </div>
    <div class="col">
      <p class="heading">Docs</p>
      <a href="/quickstart">Quickstart</a>
      <a href="/manual">Manual</a>
      <a href="/faq">FAQ</a>
    </div>
    <div class="col">
      <p class="heading">More</p>
      <a href="/blog">Blog</a>
      <a href="/legal">Legal &amp; privacy</a>
    </div>
  </div>
  <div class="rule"></div>
  <div class="meta">© {year} ARCADIA · arcadiasurvival.com</div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--rule);
    margin-top: var(--space-8);
    padding: var(--space-6) var(--space-4) var(--space-4);
  }
  .inner {
    max-width: var(--container);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-5);
  }
  .col { display: flex; flex-direction: column; gap: var(--space-2); }
  .col a {
    text-decoration: none;
    color: var(--ink-muted);
    font-size: 0.95rem;
  }
  .col a:hover { color: var(--ink); }
  .heading {
    font-family: var(--mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink);
    margin-bottom: var(--space-1);
  }
  .brand {
    font-family: var(--serif);
    font-weight: 700;
    font-size: var(--step-1);
    color: var(--ink);
  }
  .tagline { color: var(--ink-muted); font-size: 0.95rem; }
  .rule {
    max-width: var(--container);
    margin: var(--space-5) auto 0;
    border-top: 1px solid var(--rule);
  }
  .meta {
    max-width: var(--container);
    margin: var(--space-3) auto 0;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--ink-muted);
  }
  @media (max-width: 640px) {
    .inner { grid-template-columns: 1fr 1fr; }
  }
</style>
