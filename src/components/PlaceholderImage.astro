---
interface Props {
  slot: string;
  width?: number;
  height?: number;
  caption?: string;
}
const { slot: slotName, width = 1200, height = 800, caption } = Astro.props;
const aspect = `${width} / ${height}`;
---
<figure data-slot={slotName}>
  <div class="ph" style={`aspect-ratio: ${aspect}`}>
    <span class="label">{slotName}</span>
    <span class="dims">{width}×{height}</span>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  figure { margin: 0; }
  .ph {
    width: 100%;
    background: var(--bg-alt);
    border: 2px dashed var(--rule);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    color: var(--ink-muted);
    font-family: var(--mono);
  }
  .label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .dims { font-size: 0.75rem; }
  figcaption {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--ink-muted);
    margin-top: var(--space-2);
  }
</style>
